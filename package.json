{
  "name": "connexto-minc-hub",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Sistema de gestão dos times da MINC TEAMS - Minha Igreja na Cidade",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @minc-hub/web dev",
    "dev:api": "pnpm --filter @minc-hub/api dev",
    "dev:mobile-webview": "pnpm --filter @minc-hub/mobile-webview start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "test:api": "pnpm --filter @minc-teams/api test",
    "typecheck": "turbo run type-check",
    "typecheck:web": "pnpm --filter @minc-hub/web type-check",
    "typecheck:api": "pnpm --filter @minc-teams/api type-check",
    "clean": "turbo run clean",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.7.5"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.2.48",
      "@types/react-dom": "^18.2.18",
      "tar": ">=7.5.7",
      "minimatch": ">=10.1.2",
      "@isaacs/brace-expansion": ">=5.0.1",
      "handlebars": ">=4.7.9",
      "glob": ">=10.5.0",
      "undici": ">=7.0.0",
      "node-forge": ">=1.3.4",
      "picomatch": ">=4.0.4",
      "yaml": ">=2.8.3",
      "socket.io-parser": ">=4.2.6",
      "lodash": ">=4.18.1",
      "qs": ">=6.15.0",
      "js-yaml": ">=4.1.1",
      "diff": ">=5.2.0",
      "file-type": ">=20.5.0",
      "@xmldom/xmldom": ">=0.9.9",
      "rollup": ">=4.59.0",
      "multer": ">=2.1.1",
      "serialize-javascript": ">=7.0.5",
      "flatted": ">=3.4.2",
      "path-to-regexp": ">=0.1.13",
      "webpack": ">=5.104.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
